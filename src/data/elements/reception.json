            "type": "dialog",
            "data": {
              "dialogues": [
                { "text": "A Janus Corp é líder em inovação tecnológica." },
                { "text": "Fundada há 10 anos, temos escritórios em 5 países." },
                { "text": "Posso ajudar com mais alguma coisa?" }
              ]
