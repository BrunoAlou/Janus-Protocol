%%{init: {'theme': 'dark', 'themeVariables': { 'primaryColor': '#00d9ff', 'primaryTextColor': '#fff', 'primaryBorderColor': '#00d9ff', 'lineColor': '#00d9ff', 'secondaryColor': '#1a1a2e', 'tertiaryColor': '#2a2a3e'}}}%%

flowchart TB
    %% Entrada
    START(("🎮 Jogador"))
    
    %% Interação
    START -->|"Tecla E"| INTERACT["🎯 Interação"]
    
    %% Tipos de Elemento
    INTERACT --> NPC["💬 NPC"]
    INTERACT --> TERMINAL["🖥️ Terminal"]
    INTERACT --> DOOR["🚪 Porta"]
    INTERACT --> OBJECT["📦 Objeto"]
    
    %% Ações possíveis
    NPC --> DIALOG["📝 Diálogo"]
    NPC --> DILEMMA["⚖️ Dilema"]
    TERMINAL --> MINIGAME["🎮 Minigame"]
    TERMINAL --> INFO["ℹ️ Informação"]
    DOOR --> SCENE["🗺️ Mudar Cena"]
    OBJECT --> ITEM["🔍 Examinar"]
    
    %% Dilemas - Único caminho para GPI
    subgraph DECISIONS["⚖️ Sistema de Decisões"]
        DILEMMA --> CHOICE{"Escolha"}
        CHOICE -->|"Opção A"| IMPACT_A["📊 +Eixo X / -Eixo Y"]
        CHOICE -->|"Opção B"| IMPACT_B["📊 +Eixo Y / -Eixo X"]
    end
    
    %% GPI
    IMPACT_A --> GPI["📈 GPI Score"]
    IMPACT_B --> GPI
    
    %% Perfil Final
    GPI --> PROFILE["👤 Perfil Comportamental"]
    
    %% Jornadas (paralelo)
    subgraph JOURNEYS["🗺️ Jornadas"]
        J_STAGE["Estágio Atual"]
        J_STAGE -->|"interaction"| J_NPC["Falar com NPC"]
        J_STAGE -->|"exploration"| J_FIND["Encontrar Local"]
        J_STAGE -->|"minigame"| J_PLAY["Completar Desafio"]
        J_STAGE -->|"decision"| J_CHOOSE["Fazer Escolha"]
    end
    
    %% Conexões Jornadas
    J_NPC --> DIALOG
    J_CHOOSE --> DILEMMA
    J_PLAY --> MINIGAME
    
    %% Minigames (entretenimento, sem GPI)
    subgraph GAMES["🎮 Minigames"]
        MINIGAME --> MG_LIST["Quiz | Memory | Puzzle<br/>Typing | Tetris | Snake"]
        MG_LIST --> MG_RESULT["✅ Concluído"]
    end
    
    %% Estilos
    classDef start fill:#1a1a2e,stroke:#00d9ff,stroke-width:3px,color:#fff
    classDef interact fill:#2a2a3e,stroke:#00ffff,stroke-width:2px,color:#fff
    classDef decision fill:#3a2a2e,stroke:#ffff00,stroke-width:2px,color:#fff
    classDef gpi fill:#2a3a2e,stroke:#00ff00,stroke-width:2px,color:#fff
    classDef minigame fill:#2a2a3e,stroke:#ff00ff,stroke-width:1px,color:#fff
    
    class START start
    class INTERACT,NPC,TERMINAL,DOOR,OBJECT interact
    class DILEMMA,CHOICE,IMPACT_A,IMPACT_B decision
    class GPI,PROFILE gpi
    class MINIGAME,MG_LIST,MG_RESULT minigame
