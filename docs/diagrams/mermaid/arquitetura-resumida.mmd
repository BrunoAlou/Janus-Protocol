    end
    
    subgraph GAMEPLAY["⚡ Gameplay"]
        MAPS --> PLAYER["👤 Player"]
        MAPS --> ELEMENTS["🎯 Elementos"]
        MAPS --> NPCS["👥 NPCs"]
    end
    
    subgraph DATA["📊 Dados"]
        ELEMENTS --> DECISIONS["⚖️ Decisões"]
        ELEMENTS --> JOURNEYS["🗺️ Jornadas"]
        MINI --> SCORES["📈 Scores"]
    end
    
    subgraph TELEMETRY["📡 Telemetria"]
        PLAYER --> TEL["telemetry.js"]
        DECISIONS --> TEL
        SCORES --> TEL
        TEL --> BACKEND["🌐 Backend"]
    end
    
    %% Estilos
    classDef core fill:#1a1a2e,stroke:#00d9ff,stroke-width:2px,color:#fff
    classDef scene fill:#2a2a3e,stroke:#00ffff,stroke-width:1px,color:#fff
    classDef gameplay fill:#2a3a2e,stroke:#00ff00,stroke-width:1px,color:#fff
